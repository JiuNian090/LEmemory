.card-group-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
}

.item-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  display: block;
}

.item-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.item-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.item-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}