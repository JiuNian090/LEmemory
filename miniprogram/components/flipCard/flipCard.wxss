.flip-card {
  width: 100%;
  height: 400rpx;
  perspective: 1000px;
}

.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
}

.card-inner.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background: var(--card-bg);
  border-radius: 16rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  text-align: center;
}

.card-face.back {
  transform: rotateY(180deg);
  background: var(--bg-color);
}