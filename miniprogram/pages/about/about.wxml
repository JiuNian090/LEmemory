<view class="container">
  <!-- 应用信息头部 -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">{{appName}}</text>
      <text class="header-version">v{{appVersion}}</text>
      <text class="header-subtitle">{{appDesc}}</text>
    </view>
  </view>

  <!-- 更新日志板块 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon changelog-icon">
        <text class="icon-text">📋</text>
      </view>
      <text class="section-title">更新日志</text>
    </view>
    <view class="section-body">
      <view class="timeline">
        <view class="timeline-item" wx:for="{{changelog}}" wx:key="version" wx:for-item="version">
          <!-- 时间线节点 -->
          <view class="timeline-dot"></view>
          <!-- 内容卡片 -->
          <view class="timeline-content">
            <view class="version-header">
              <text class="version-tag">v{{version.version}}</text>
              <text class="version-date">{{version.date}}</text>
            </view>
            <view class="change-group" wx:for="{{version.changes}}" wx:key="type" wx:for-item="group">
              <text class="change-type">{{group.type}}</text>
              <view class="change-list">
                <text class="change-item" wx:for="{{group.items}}" wx:for-index="idx" wx:key="idx">{{item}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
