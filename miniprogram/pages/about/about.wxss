page {
  background: var(--bg-color);
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 头部 ========== */
.page-header {
  margin: 30rpx 30rpx 30rpx;
  padding: 64rpx 30rpx;
  background: var(--header-gradient);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.header-content {
  text-align: center;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--header-text);
  margin-bottom: 12rpx;
}

.header-version {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 400;
}

/* ========== 区块卡片 ========== */
.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.changelog-icon {
  background: linear-gradient(135deg, #f6ffed 0%, #f0fff0 100%);
}

@media (prefers-color-scheme: dark) {
  .changelog-icon {
    background: linear-gradient(135deg, #0a2e1a 0%, #0a2e1a 100%) !important;
  }
}

.icon-text {
  font-size: 28rpx;
}

.section-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-body {
  padding: 0 30rpx 30rpx;
}

/* ========== 时间线 ========== */
.timeline {
  position: relative;
  padding: 20rpx 0;
}

/* 左侧竖线 */
.timeline::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 30rpx;
  bottom: 30rpx;
  width: 4rpx;
  background: var(--primary-color);
  border-radius: 4rpx;
  opacity: 0.3;
}

.timeline-item {
  position: relative;
  padding-left: 52rpx;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

/* 时间线圆点 */
.timeline-dot {
  position: absolute;
  left: 4rpx;
  top: 10rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--primary-color);
  border: 4rpx solid var(--card-bg);
  box-shadow: 0 0 0 4rpx var(--primary-color);
  z-index: 1;
}

/* 时间线内容卡片 */
.timeline-content {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 24rpx;
}

.version-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.version-tag {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-dark);
}

.version-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 变更组 */
.change-group {
  margin-bottom: 16rpx;
}

.change-group:last-child {
  margin-bottom: 0;
}

.change-type {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.change-list {
  padding-left: 8rpx;
}

.change-item {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  padding: 4rpx 0;
  padding-left: 20rpx;
  position: relative;
}

.change-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--text-tertiary);
  opacity: 0.5;
}

/* ========== 深色模式适配 ========== */
@media (prefers-color-scheme: dark) {
  .timeline::before {
    opacity: 0.5;
  }

  .timeline-dot {
    border-color: var(--card-bg);
  }

  .version-tag {
    color: var(--primary-color);
  }
}
