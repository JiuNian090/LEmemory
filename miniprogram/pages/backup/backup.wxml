<view class="container">
  <!-- 存储信息卡片 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon storage-icon">
        <text class="icon-text">💾</text>
      </view>
      <text class="section-title">存储空间</text>
    </view>
    <view class="section-body">
      <view class="storage-info">
        <view class="storage-row">
          <text class="storage-label">已使用</text>
          <text class="storage-value">{{ formatSize(storageInfo.used) }}</text>
        </view>
        <view class="storage-row">
          <text class="storage-label">总空间</text>
          <text class="storage-value">{{ formatSize(storageInfo.limit) }}</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{ storageInfo.usedPercent }}%"></view>
        </view>
        <text class="progress-text">{{ storageInfo.usedPercent }}%</text>
      </view>
    </view>
  </view>

  <!-- 同步状态卡片 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon sync-icon">
        <text class="icon-text">🔄</text>
      </view>
      <text class="section-title">同步状态</text>
    </view>
    <view class="section-body">
      <view class="sync-status">
        <view class="sync-row">
          <text class="sync-label">同步状态</text>
          <text class="sync-value {{ syncStatus.isSyncing ? 'syncing' : 'idle' }}">
            {{ syncStatus.isSyncing ? '同步中...' : '空闲' }}
          </text>
        </view>
        <view class="sync-row" wx:if="{{ syncStatus.lastSyncTime }}">
          <text class="sync-label">上次同步</text>
          <text class="sync-value">{{ syncStatus.lastSyncTime }}</text>
        </view>
        <view class="sync-row" wx:if="{{ syncStatus.pendingItems > 0 }}">
          <text class="sync-label">待同步</text>
          <text class="sync-value warning">{{ syncStatus.pendingItems }} 项</text>
        </view>
        <button class="action-btn sync-btn" bindtap="onManualSync" disabled="{{ syncStatus.isSyncing }}">
          {{ syncStatus.isSyncing ? '同步中...' : '立即同步' }}
        </button>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="action-btn primary" bindtap="onCreateBackup">
      📦 创建备份
    </button>
  </view>

  <!-- 备份列表 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon backup-icon">
        <text class="icon-text">📋</text>
      </view>
      <text class="section-title">备份列表</text>
    </view>
    <view class="section-body">
      <view wx:if="{{ loading }}" class="loading-tip">
        <text>加载中...</text>
      </view>
      
      <view wx:elif="{{ backups.length === 0 }}" class="empty-tip">
        <text>暂无备份</text>
      </view>
      
      <view wx:else class="backup-list">
        <view 
          wx:for="{{ backups }}" 
          wx:key="backupId" 
          class="backup-item"
          data-backup="{{ item }}"
        >
          <view class="backup-header">
            <view class="backup-time-row">
              <text class="backup-time">{{ item.backupTime.toLocaleString() }}</text>
              <text class="cloud-badge">☁️ 云端</text>
            </view>
            <view class="backup-actions">
              <button class="mini-btn restore-btn" bindtap="onRestoreBackup" data-backup="{{ item }}">恢复</button>
              <button class="mini-btn delete-btn" bindtap="deleteBackup" data-backup="{{ item }}">删除</button>
            </view>
          </view>
          <view wx:if="{{ item.description }}" class="backup-desc">
            {{ item.description }}
          </view>
          <view class="backup-stats">
            <view class="stat-item">
              <text class="stat-icon">📚</text>
              <text class="stat-text">{{ item.cardGroupsCount }} 卡组</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">🃏</text>
              <text class="stat-text">{{ item.cardsCount }} 卡牌</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">📝</text>
              <text class="stat-text">{{ item.studyRecordsCount }} 记录</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">⭐</text>
              <text class="stat-text">{{ item.favoritesCount }} 收藏</text>
            </view>
          </view>
          <view class="backup-size">
            <text>大小: {{ formatSize(item.dataSize) }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 备份描述弹窗 -->
  <view wx:if="{{ showDescriptionModal }}" class="modal-mask" bindtap="cancelCreateBackup">
    <view class="modal-container" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">创建备份</text>
        <view class="modal-close" bindtap="cancelCreateBackup">
          <text class="close-icon">×</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <text class="form-label">备份描述（可选）</text>
          <input 
            class="form-input" 
            placeholder="输入备份描述..." 
            value="{{ currentDescription }}"
            bindinput="onDescriptionInput"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn btn-cancel" bindtap="cancelCreateBackup">取消</button>
        <button class="modal-btn btn-confirm" bindtap="confirmCreateBackup">创建</button>
      </view>
    </view>
  </view>

  <!-- 恢复确认弹窗 -->
  <view wx:if="{{ showRestoreConfirm }}" class="modal-mask" bindtap="cancelRestoreBackup">
    <view class="modal-container" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">确认恢复</text>
        <view class="modal-close" bindtap="cancelRestoreBackup">
          <text class="close-icon">×</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="warning-text">
          <text class="warning-icon">⚠️</text>
          <text class="warning-content">
            恢复备份将覆盖当前所有数据，此操作不可撤销！确定要恢复吗？
          </text>
        </view>
        <view wx:if="{{ selectedBackup }}" class="backup-preview">
          <text class="preview-label">备份时间：</text>
          <text class="preview-value">{{ selectedBackup.backupTime.toLocaleString() }}</text>
          <text class="preview-label" wx:if="{{ selectedBackup.description }}">备份描述：</text>
          <text class="preview-value" wx:if="{{ selectedBackup.description }}">{{ selectedBackup.description }}</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn btn-cancel" bindtap="cancelRestoreBackup">取消</button>
        <button class="modal-btn btn-danger" bindtap="confirmRestoreBackup">确认恢复</button>
      </view>
    </view>
  </view>
</view>
