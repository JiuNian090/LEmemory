<view class="container">
  <!-- 页面标题区 -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">☁️ 云备份</text>
      <text class="header-subtitle">保护你的数据安全</text>
    </view>
  </view>

  <!-- 云备份状态卡片 -->
  <view class="section">
    <view class="section-header">
      <view class="section-header-left">
        <view class="section-icon cloud-icon">
          <text class="icon-text">☁️</text>
        </view>
        <text class="section-title">云备份</text>
      </view>
      <view class="backup-status-badge" catchtap="onStatusTap">
        <view class="status-breath status-{{backupStatus.type}}"></view>
        <text class="status-label">{{backupStatus.label}}</text>
      </view>
    </view>
    <view class="section-body">
      <view class="btn-grid">
        <view class="grid-btn backup-btn" bindtap="onCreateBackup">
          <text class="btn-icon">⬆️</text>
          <text class="btn-text">备份</text>
        </view>
        <view class="grid-btn restore-btn" bindtap="onRestoreLatest">
          <text class="btn-icon">⬇️</text>
          <text class="btn-text">恢复</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 存储用量卡片 -->
  <view class="section">
    <view class="section-header">
      <view class="section-header-left">
        <view class="section-icon storage-icon">
          <text class="icon-text">☁️</text>
        </view>
        <text class="section-title">云端存储用量</text>
      </view>
      <text class="storage-used-label">{{ formatSize(storageInfo.used) }}</text>
    </view>
    <view class="section-body storage-body">
      <view class="storage-bar-track">
        <view class="storage-bar-fill" style="width: {{ storageInfo.usedPercent }}%"></view>
      </view>
      <view class="storage-bar-footer">
        <text class="storage-bar-pct">{{ storageInfo.usedPercent }}%</text>
        <text class="storage-bar-desc">/ 500 MB 已使用</text>
      </view>
    </view>
  </view>

  <!-- 备份历史列表 -->
  <view class="section">
    <view class="section-header">
      <view class="section-header-left">
        <view class="section-icon history-icon">
          <text class="icon-text">📋</text>
        </view>
        <text class="section-title">备份历史</text>
      </view>
    </view>
    <view class="section-body">
      <view wx:if="{{ loading }}" class="loading-tip">
        <text>加载中...</text>
      </view>

      <view wx:elif="{{ backups.length === 0 }}" class="empty-tip">
        <text>暂无备份</text>
      </view>

      <view wx:else class="backup-list">
        <view wx:for="{{ backups }}" wx:key="backupId" class="backup-item">
          <view class="backup-header">
            <view class="backup-time-row">
              <text class="backup-time">{{ item.backupTime.toLocaleString() }}</text>
              <text class="cloud-badge">☁️ 云端</text>
            </view>
            <view class="backup-actions-right">
              <button class="mini-btn restore-btn" bindtap="onRestoreBackup" data-backup="{{ item }}">恢复</button>
              <button class="mini-btn delete-btn" bindtap="deleteBackup" data-backup="{{ item }}">删除</button>
            </view>
          </view>
          <view wx:if="{{ item.description }}" class="backup-desc">{{ item.description }}</view>
          <view class="backup-stats">
            <view class="stat-item">
              <text class="stat-icon">📚</text>
              <text class="stat-text">{{ item.cardGroupsCount }} 卡组</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">🃏</text>
              <text class="stat-text">{{ item.cardsCount }} 卡牌</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">📝</text>
              <text class="stat-text">{{ item.studyRecordsCount }} 记录</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">⭐</text>
              <text class="stat-text">{{ item.favoritesCount }} 收藏</text>
            </view>
          </view>
          <view class="backup-size">大小: {{ formatSize(item.dataSize) }}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 备份描述弹窗 -->
  <view wx:if="{{ showDescriptionModal }}" class="modal-mask" bindtap="cancelCreateBackup">
    <view class="modal-container" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title-wrapper">
          <text class="modal-title-icon">📦</text>
          <text class="modal-title">创建备份</text>
        </view>
        <view class="modal-close" bindtap="cancelCreateBackup">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="form-card">
          <view class="form-group">
            <text class="form-label">备份描述（可选）</text>
            <input class="form-input" placeholder="描述一下这个备份..." value="{{ currentDescription }}" bindinput="onDescriptionInput" />
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn btn-cancel" bindtap="cancelCreateBackup">取消</button>
        <button class="modal-btn btn-confirm" bindtap="confirmCreateBackup">创建</button>
      </view>
    </view>
  </view>

  <!-- 恢复确认弹窗 -->
  <view wx:if="{{ showRestoreConfirm }}" class="modal-mask" bindtap="cancelRestoreBackup">
    <view class="modal-container" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title-wrapper">
          <text class="modal-title-icon">⚠️</text>
          <text class="modal-title">确认恢复</text>
        </view>
        <view class="modal-close" bindtap="cancelRestoreBackup">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="warning-text">
          <text class="warning-icon">⚠️</text>
          <text class="warning-content">恢复备份将覆盖当前所有数据，此操作不可撤销！确定要恢复吗？</text>
        </view>
        <view wx:if="{{ selectedBackup }}" class="backup-preview">
          <view class="preview-row">
            <text class="preview-label">备份时间：</text>
            <text class="preview-value">{{ selectedBackup.backupTime.toLocaleString() }}</text>
          </view>
          <view class="preview-row" wx:if="{{ selectedBackup.description }}">
            <text class="preview-label">备份描述：</text>
            <text class="preview-value">{{ selectedBackup.description }}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn btn-cancel" bindtap="cancelRestoreBackup">取消</button>
        <button class="modal-btn btn-danger" bindtap="confirmRestoreBackup">确认恢复</button>
      </view>
    </view>
  </view>
</view>
