page {
  background-color: var(--bg-color);
}

.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* ========== 页面标题 ========== */
.page-header {
  margin: 0 0 24rpx;
}

.header-content {
  padding: 30rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%);
  border-radius: 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

/* ========== 区块卡片 ========== */
.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.storage-icon {
  background: linear-gradient(135deg, #60a5fa, #3b82f6);
}

.cloud-icon {
  background: linear-gradient(135deg, #a78bfa, #7c3aed);
}

.history-icon {
  background: linear-gradient(135deg, #f472b6, #ec4899);
}

.icon-text {
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-body {
  padding: 30rpx;
}

/* ========== 备份状态徽标（可点击） ========== */
.backup-status-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-color);
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.status-breath {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

/* 呼吸动画 */
@keyframes breath {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.status-breath.status-checking {
  background: var(--primary-color);
  animation: breath 1.5s ease-in-out infinite;
}

.status-breath.status-synced {
  background: var(--primary-color);
  box-shadow: 0 0 8rpx var(--primary-color);
}

.status-breath.status-local_newer {
  background: #f59e0b;
  box-shadow: 0 0 8rpx rgba(245, 158, 11, 0.5);
}

.status-breath.status-cloud_newer {
  background: #3b82f6;
  box-shadow: 0 0 8rpx rgba(59, 130, 246, 0.5);
}

.status-breath.status-unbacked {
  background: var(--text-tertiary);
}

.status-breath.status-error {
  background: #ef4444;
  box-shadow: 0 0 8rpx rgba(239, 68, 68, 0.5);
}

.status-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 按钮网格 ========== */
.btn-grid {
  display: flex;
  gap: 20rpx;
}

.grid-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border-radius: 20rpx;
  gap: 12rpx;
  border: none;
  margin: 0;
  line-height: 1;
}

.grid-btn::after {
  border: none;
}

.backup-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

.restore-btn {
  background: var(--bg-color);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-icon {
  font-size: 48rpx;
  line-height: 1;
}

.btn-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.backup-btn .btn-text {
  color: #fff;
}

/* ========== 存储信息 ========== */
.storage-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.storage-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.storage-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.storage-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.progress-bar {
  height: 12rpx;
  background: var(--border-color);
  border-radius: 6rpx;
  overflow: hidden;
  margin-top: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* ========== 备份列表 ========== */
.loading-tip,
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.backup-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.backup-item {
  background: var(--bg-color);
  border-radius: 20rpx;
  padding: 24rpx;
}

.backup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.backup-time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.backup-time {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.cloud-badge {
  font-size: 22rpx;
  color: var(--info-color);
  background: rgba(96, 165, 250, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.backup-actions-right {
  display: flex;
  gap: 12rpx;
}

.backup-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.backup-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.backup-size {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.mini-btn {
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  border: none;
  line-height: 1;
}

.mini-btn::after {
  border: none;
}

.restore-btn {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.delete-btn {
  background: rgba(248, 113, 113, 0.1);
  color: var(--danger-color);
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
  animation: fadeIn 0.3s ease;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  max-width: 600rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  z-index: 999;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.3s ease;
}

.modal-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
  justify-content: space-between;
}

.modal-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-title-icon {
  font-size: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-color);
}

.close-icon {
  font-size: 36rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx 30rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  line-height: 88rpx;
}

.modal-btn::after {
  border: none;
}

.btn-cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
}

.btn-danger {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
}

.form-card {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-group {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.warning-text {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(251, 191, 36, 0.1);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.warning-icon {
  font-size: 40rpx;
  text-align: center;
}

.warning-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  text-align: center;
}

.backup-preview {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preview-row {
  display: flex;
  gap: 8rpx;
}

.preview-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.preview-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex: 1;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translate(-50%, -40%);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
}
