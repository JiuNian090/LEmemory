page {
  background-color: var(--bg-color);
}

.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.storage-icon {
  background: linear-gradient(135deg, #60a5fa, #3b82f6);
}

.sync-icon {
  background: linear-gradient(135deg, #a78bfa, #8b5cf6);
}

.backup-icon {
  background: linear-gradient(135deg, #f472b6, #ec4899);
}

.icon-text {
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-body {
  padding: 30rpx;
}

/* 存储信息 */
.storage-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.storage-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.storage-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.storage-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.progress-bar {
  height: 12rpx;
  background: var(--border-color);
  border-radius: 6rpx;
  overflow: hidden;
  margin-top: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* 同步状态 */
.sync-status {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sync-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sync-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.sync-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.sync-value.syncing {
  color: var(--primary-color);
}

.sync-value.idle {
  color: var(--text-secondary);
}

.sync-value.warning {
  color: var(--warning-color);
}

/* 操作按钮 */
.action-section {
  margin-bottom: 24rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
}

.action-btn.sync-btn {
  background: var(--bg-color);
  color: var(--text-primary);
  margin-top: 16rpx;
}

.action-btn[disabled] {
  opacity: 0.5;
}

.mini-btn {
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  border: none;
  line-height: 1;
}

.restore-btn {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.delete-btn {
  background: rgba(248, 113, 113, 0.1);
  color: var(--danger-color);
}

/* 备份列表 */
.loading-tip,
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.backup-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.backup-item {
  background: var(--bg-color);
  border-radius: 20rpx;
  padding: 24rpx;
}

.backup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.backup-time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.backup-time {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.cloud-badge {
  font-size: 22rpx;
  color: var(--info-color);
  background: rgba(96, 165, 250, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.backup-actions {
  display: flex;
  gap: 12rpx;
}

.backup-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.backup-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.backup-size {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
  animation: fadeIn 0.3s ease;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  max-width: 600rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  z-index: 999;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.3s ease;
}

.modal-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
  justify-content: center;
  position: relative;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  text-align: center;
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.modal-close {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-color);
}

.close-icon {
  font-size: 36rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx 30rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
}

.btn-danger {
  background: var(--danger-gradient);
  color: white;
}

/* 表单 */
.form-group {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-color);
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 警告文本 */
.warning-text {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(251, 191, 36, 0.1);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.warning-icon {
  font-size: 40rpx;
  text-align: center;
}

.warning-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  text-align: center;
}

/* 备份预览 */
.backup-preview {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preview-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.preview-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translate(-50%, -40%);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
}
