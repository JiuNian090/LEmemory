<view class="container">
  <view class="tabs-wrapper">
    <view class="tabs">
      <block wx:for="{{tabs}}" wx:key="index">
        <view class="tab-item {{currentTab === index ? 'active' : ''}}" bindtap="switchTab" data-index="{{index}}">
          {{item}}
        </view>
      </block>
    </view>
  </view>

  <view class="tab-content">
    <!-- 学习标签页 -->
    <view wx:if="{{currentTab === 0}}" class="study-section">
      <view wx:if="{{!isStudying}}" class="study-dashboard">
        <!-- 卡牌组信息 -->
        <view class="group-info-card">
          <view class="group-icon">🎴</view>
          <view class="group-details">
            <view class="group-title">{{title}}</view>
            <view class="group-stats">
              <text>学习进度: {{studiedCards}}/{{totalCards}}</text>
            </view>
          </view>
        </view>

        <!-- 今日学习统计 -->
        <view class="today-stats-card">
          <view class="stat-item">
            <view class="stat-value today">{{todayStats.toLearn}}</view>
            <view class="stat-label">今日待学</view>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <view class="stat-value review">{{todayStats.toReview}}</view>
            <view class="stat-label">今日待复习</view>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <view class="stat-value time">{{formatTime(todayStats.studiedTime)}}</view>
            <view class="stat-label">今日已学时长</view>
          </view>
        </view>

        <!-- 开始学习按钮 -->
        <view class="start-study-btn" bindtap="startStudy">
          <text class="btn-icon">▶️</text>
          <text class="btn-text">开始学习</text>
        </view>
        <view class="study-hint">预计用时: {{totalCards > 0 ? Math.ceil(totalCards * 2) : 0}}分钟</view>

        <!-- 快捷功能按钮 -->
        <view class="quick-actions">
          <view class="quick-action-btn" bindtap="shareCardGroup">
            <text class="action-icon">📤</text>
            <text class="action-text">分享卡牌组</text>
          </view>
          <view class="quick-action-btn" bindtap="importCards">
            <text class="action-icon">📥</text>
            <text class="action-text">导入卡牌</text>
          </view>
          <view class="quick-action-btn" bindtap="startStudy">
            <text class="action-icon">📝</text>
            <text class="action-text">测验</text>
          </view>
        </view>

        <!-- 掌握程度图表 -->
        <view class="mastery-card">
          <view class="section-title">掌握程度</view>
          <view class="mastery-content">
            <view class="donut-chart">
              <view class="donut-segment difficult" style="transform: rotate(0deg);"></view>
              <view class="donut-segment good" style="transform: rotate({{goodDeg}});"></view>
              <view class="donut-segment basic" style="transform: rotate({{basicDeg}});"></view>
              <view class="donut-segment not-started" style="transform: rotate({{notStartedDeg}});"></view>
              <view class="donut-center">
                <view class="donut-number">{{totalCards}}</view>
                <view class="donut-label">总卡牌</view>
              </view>
            </view>
            <view class="mastery-legend">
              <view class="legend-item">
                <view class="legend-dot not-started"></view>
                <view class="legend-label">未掌握</view>
                <view class="legend-value">{{masteryData.notStarted}}张</view>
              </view>
              <view class="legend-item">
                <view class="legend-dot basic"></view>
                <view class="legend-label">基本掌握</view>
                <view class="legend-value">{{masteryData.basic}}张</view>
              </view>
              <view class="legend-item">
                <view class="legend-dot good"></view>
                <view class="legend-label">良好掌握</view>
                <view class="legend-value">{{masteryData.good}}张</view>
              </view>
              <view class="legend-item">
                <view class="legend-dot difficult"></view>
                <view class="legend-label">疑难卡片</view>
                <view class="legend-value">{{masteryData.difficult}}张</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 学习模式 -->
      <view wx:if="{{isStudying && cards.length > 0}}" class="study-mode">
        <view class="card-wrapper" bindtap="flipCard">
          <view class="study-card {{isFlipped ? 'flipped' : ''}}">
            <view class="card-face front">
              <view class="card-label">问题</view>
              <view class="card-text">{{cards[currentCardIndex].front}}</view>
            </view>
            <view class="card-face back">
              <view class="card-label">答案</view>
              <view class="card-text">{{cards[currentCardIndex].back}}</view>
            </view>
          </view>
        </view>
        <view class="card-hint">点击卡片翻转</view>
        <view class="card-nav">
          <button class="nav-btn prev" bindtap="prevCard" disabled="{{currentCardIndex === 0}}">
            ‹ 上一张
          </button>
          <view class="card-index">
            <text class="current">{{currentCardIndex + 1}}</text>
            <text class="separator">/</text>
            <text class="total">{{cards.length}}</text>
          </view>
          <button class="nav-btn next" bindtap="nextCard" disabled="{{currentCardIndex === cards.length - 1}}">
            下一张 ›
          </button>
        </view>
      </view>

      <view wx:if="{{!isStudying && cards.length === 0}}" class="empty-state">
        <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
        <view class="empty-text">暂无卡牌</view>
        <view class="empty-desc">切换到"卡牌"标签页添加</view>
      </view>
    </view>

    <!-- 目录标签页 -->
    <view wx:if="{{currentTab === 1}}" class="catalog-section">
      <block wx:if="{{cards.length > 0}}">
        <view wx:for="{{cards}}" wx:key="cardId" class="catalog-item">
          <view class="catalog-num">{{index + 1}}</view>
          <view class="catalog-content">
            <view class="catalog-question">{{item.front}}</view>
            <view class="catalog-answer" wx:if="{{item.back}}">{{item.back}}</view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-state">
        <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
        <view class="empty-text">暂无卡牌</view>
      </view>
    </view>

    <!-- 卡牌标签页 -->
    <view wx:if="{{currentTab === 2}}" class="cards-section">
      <view class="add-card-btn" bindtap="showAddCardDialog">
        <text class="add-icon">+</text>
        <text class="add-text">添加卡牌</text>
      </view>
      <block wx:if="{{cards.length > 0}}">
        <view class="card-list">
          <view wx:for="{{cards}}" wx:key="cardId" class="card-item">
            <view class="item-header">
              <view class="item-index">{{index + 1}}</view>
              <view class="item-actions">
                <view class="action-btn edit" bindtap="showEditCardDialog" data-cardid="{{item.cardId}}" data-front="{{item.front}}" data-back="{{item.back}}">
                  编辑
                </view>
                <view class="action-btn delete" bindtap="deleteCard" data-cardid="{{item.cardId}}">
                  删除
                </view>
              </view>
            </view>
            <view class="item-content">
              <view class="item-question">
                <text class="label">Q:</text>
                <text class="text">{{item.front}}</text>
              </view>
              <view class="item-answer">
                <text class="label">A:</text>
                <text class="text">{{item.back}}</text>
              </view>
            </view>
            <view class="item-footer">
              <view class="favorite-btn {{favoriteCardIds.has(item.cardId) ? 'favorited' : ''}}" bindtap="toggleFavorite" data-cardid="{{item.cardId}}">
                {{favoriteCardIds.has(item.cardId) ? '★ 已收藏' : '☆ 收藏'}}
              </view>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-state">
        <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
        <view class="empty-text">暂无卡牌</view>
        <view class="empty-desc">点击上方按钮添加</view>
      </view>
    </view>

    <!-- 收藏标签页 -->
    <view wx:if="{{currentTab === 3}}" class="favorites-section">
      <block wx:if="{{favorites.length > 0}}">
        <view wx:for="{{favorites}}" wx:key="favoriteId" class="favorite-item">
          <view class="favorite-icon">★</view>
          <view class="favorite-content" wx:if="{{item.card}}">
            <view class="favorite-question">{{item.card.front}}</view>
            <view class="favorite-answer">{{item.card.back}}</view>
          </view>
          <view class="favorite-content" wx:else>
            <view class="favorite-question">卡牌已删除</view>
          </view>
          <view class="unfavorite-btn" bindtap="toggleFavorite" data-cardid="{{item.cardId}}">
            取消收藏
          </view>
        </view>
      </block>
      <view wx:else class="empty-state">
        <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
        <view class="empty-text">暂无收藏</view>
        <view class="empty-desc">在"卡牌"标签页收藏喜欢的卡牌</view>
      </view>
    </view>
  </view>

  <!-- 添加/编辑卡牌弹窗 -->
  <view class="modal-overlay" wx:if="{{showCardDialog}}" bindtap="closeDialog">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{dialogMode === 'add' ? '添加卡牌' : '编辑卡牌'}}</text>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">正面（问题） *</text>
          <textarea class="textarea-field" placeholder="请输入卡牌正面内容" value="{{newFront}}" bindinput="onFrontInput" maxlength="200" auto-height></textarea>
        </view>
        <view class="input-group">
          <text class="input-label">背面（答案） *</text>
          <textarea class="textarea-field" placeholder="请输入卡牌背面内容" value="{{newBack}}" bindinput="onBackInput" maxlength="500" auto-height></textarea>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-cancel" bindtap="closeDialog">取消</button>
        <button class="btn btn-confirm" bindtap="confirmSaveCard">保存</button>
      </view>
    </view>
  </view>
</view>
