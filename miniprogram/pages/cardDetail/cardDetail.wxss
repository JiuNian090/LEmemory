.tabs-wrapper {
  background: var(--card-bg);
  padding: 20rpx 30rpx;
  margin: 0 30rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: var(--shadow);
}

.tabs {
  display: flex;
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: var(--card-bg);
  color: var(--primary-color);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(52, 211, 153, 0.15);
}

.tab-content {
  padding: 0;
}

.study-section {
  padding: 0 30rpx;
}

.card-wrapper {
  perspective: 1000px;
  margin-bottom: 30rpx;
}

.study-card {
  position: relative;
  width: 100%;
  min-height: 500rpx;
  transform-style: preserve-3d;
  transition: transform 0.6s ease;
}

.study-card.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  min-height: 500rpx;
  backface-visibility: hidden;
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-shadow: var(--shadow-hover);
}

.card-face.back {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
}

.card-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 20rpx;
  text-align: center;
}

.card-face.back .card-label {
  color: rgba(255, 255, 255, 0.9);
}

.card-text {
  font-size: 34rpx;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.6;
  font-weight: 500;
}

.card-face.back .card-text {
  color: #ffffff;
}

.card-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 40rpx;
}

.card-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-btn {
  width: 180rpx;
  height: 88rpx;
  background: var(--card-bg);
  color: var(--primary-color);
  border-radius: 44rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 2rpx solid var(--primary-color);
  padding: 0;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.2);
}

.nav-btn::after {
  border: none;
}

.nav-btn[disabled] {
  background: var(--bg-color);
  color: var(--text-tertiary);
  border-color: var(--border-color);
  box-shadow: none;
}

.card-index {
  display: flex;
  align-items: baseline;
  font-size: 28rpx;
}

.card-index .current {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.card-index .separator {
  margin: 0 8rpx;
  color: var(--text-tertiary);
}

.card-index .total {
  color: var(--text-tertiary);
}

.catalog-section,
.cards-section,
.favorites-section {
  padding: 0 30rpx;
}

.add-card-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(52, 211, 153, 0.3);
}

.add-icon {
  font-size: 40rpx;
  color: #ffffff;
  margin-right: 12rpx;
  font-weight: 300;
}

.add-text {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.catalog-item,
.card-item,
.favorite-item {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: var(--shadow);
}

.catalog-num {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.catalog-content {
  flex: 1;
}

.catalog-question {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.catalog-answer {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.item-header {
  margin-right: 20rpx;
}

.item-index {
  width: 50rpx;
  height: 50rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-color);
  font-size: 24rpx;
  font-weight: 600;
}

.item-content {
  flex: 1;
}

.item-question,
.item-answer {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.item-answer {
  margin-bottom: 0;
}

.item-question .label {
  color: var(--primary-color);
  font-weight: 600;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.item-answer .label {
  color: var(--primary-dark);
  font-weight: 600;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.item-question .text,
.item-answer .text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.item-answer .text {
  color: var(--text-secondary);
}

.favorite-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  color: var(--warning-color);
}

.favorite-content {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.25;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}
