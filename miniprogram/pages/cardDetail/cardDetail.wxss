.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding-bottom: 40rpx;
}

.tabs-wrapper {
  background: rgba(255, 255, 255, 0.05);
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #888;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab-item.active {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  color: #fff;
  font-weight: 600;
}

.tab-content {
  padding: 0 30rpx;
}

/* 学习仪表盘 */
.study-dashboard {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 卡牌组信息卡片 */
.group-info-card {
  background: linear-gradient(135deg, rgba(52, 211, 153, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
  border: 1rpx solid rgba(52, 211, 153, 0.2);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.group-icon {
  font-size: 60rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
}

.group-details {
  flex: 1;
}

.group-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.group-stats {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 今日统计卡片 */
.today-stats-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.today-stats-card .stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-value.today {
  color: #34d399;
}

.stat-value.review {
  color: #fbbf24;
}

.stat-value.time {
  color: #60a5fa;
  font-size: 28rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 开始学习按钮 */
.start-study-btn {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-radius: 50rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 10rpx;
  box-shadow: 0 8rpx 30rpx rgba(52, 211, 153, 0.3);
  transition: all 0.3s ease;
}

.start-study-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.study-hint {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
}

/* 快捷操作按钮 */
.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}

.quick-action-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.quick-action-btn:active {
  background: rgba(255, 255, 255, 0.12);
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 掌握程度卡片 */
.mastery-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.mastery-content {
  display: flex;
  gap: 30rpx;
}

.donut-chart {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: conic-gradient(
    #6b7280 0deg,
    #6b7280 var(--not-started-deg, 0deg),
    #fbbf24 var(--not-started-deg, 0deg),
    #fbbf24 var(--basic-deg, 0deg),
    #34d399 var(--basic-deg, 0deg),
    #34d399 var(--good-deg, 0deg),
    #f87171 var(--good-deg, 0deg),
    #f87171 360deg
  );
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.donut-chart::before {
  content: '';
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  background: rgba(26, 26, 46, 1);
  border-radius: 50%;
}

.donut-center {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.donut-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.donut-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.mastery-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-dot.not-started {
  background: #6b7280;
}

.legend-dot.basic {
  background: #fbbf24;
}

.legend-dot.good {
  background: #34d399;
}

.legend-dot.difficult {
  background: #f87171;
}

.legend-label {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.legend-value {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

/* 学习模式 */
.study-mode {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-wrapper {
  perspective: 1000px;
  width: 100%;
  margin-bottom: 30rpx;
}

.study-card {
  position: relative;
  width: 100%;
  min-height: 500rpx;
  transform-style: preserve-3d;
  transition: transform 0.6s ease;
}

.study-card.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  min-height: 500rpx;
  backface-visibility: hidden;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.card-face.back {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, rgba(52, 211, 153, 0.2) 0%, rgba(16, 185, 129, 0.1) 100%);
  border: 1rpx solid rgba(52, 211, 153, 0.3);
}

.card-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.card-text {
  font-size: 34rpx;
  color: #fff;
  text-align: center;
  line-height: 1.6;
  font-weight: 500;
}

.card-hint {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
}

.card-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.nav-btn {
  width: 160rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn::after {
  border: none;
}

.nav-btn[disabled] {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.3);
}

.card-index {
  display: flex;
  align-items: baseline;
  font-size: 28rpx;
}

.card-index .current {
  font-size: 48rpx;
  font-weight: 700;
  color: #34d399;
}

.card-index .separator {
  margin: 0 8rpx;
  color: rgba(255, 255, 255, 0.4);
}

.card-index .total {
  color: rgba(255, 255, 255, 0.5);
}

/* 目录、卡牌、收藏页面通用 */
.catalog-section,
.cards-section,
.favorites-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.add-card-btn {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 30rpx rgba(52, 211, 153, 0.2);
}

.add-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 300;
}

.add-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.catalog-item,
.card-item,
.favorite-item {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.catalog-item {
  flex-direction: row;
  align-items: flex-start;
}

.catalog-num {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.catalog-content {
  flex: 1;
}

.catalog-question {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.catalog-answer {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-index {
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #34d399;
  font-size: 20rpx;
  font-weight: 600;
}

.item-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.action-btn.edit {
  background: rgba(52, 211, 153, 0.15);
  color: #34d399;
}

.action-btn.delete {
  background: rgba(248, 113, 113, 0.15);
  color: #f87171;
}

.item-content {
  flex: 1;
}

.item-question,
.item-answer {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.item-answer {
  margin-bottom: 0;
}

.item-question .label {
  color: #34d399;
  font-weight: 600;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.item-answer .label {
  color: #10b981;
  font-weight: 600;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.item-question .text,
.item-answer .text {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  line-height: 1.5;
}

.item-answer .text {
  color: rgba(255, 255, 255, 0.7);
}

.item-footer {
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.favorite-btn {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  background: rgba(251, 191, 36, 0.1);
  color: rgba(255, 255, 255, 0.6);
}

.favorite-btn.favorited {
  background: rgba(251, 191, 36, 0.2);
  color: #fbbf24;
}

.favorite-item {
  flex-direction: row;
  align-items: flex-start;
}

.favorite-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #fbbf24;
  flex-shrink: 0;
}

.favorite-content {
  flex: 1;
}

.favorite-question {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.favorite-answer {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

.unfavorite-btn {
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  background: rgba(248, 113, 113, 0.15);
  color: #f87171;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 30rpx;
}

.modal-content {
  background: #1a1a2e;
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
  text-align: center;
}

.modal-body {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  min-height: 0;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.textarea-field {
  width: 100%;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #fff;
  min-height: 120rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
}

.btn-cancel:active {
  background: rgba(255, 255, 255, 0.15);
}

.btn-confirm {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  color: #fff;
}

.btn-confirm:active {
  opacity: 0.9;
}
