/* 局部覆盖 CSS 变量 - 仅影响当前页面 */
page {
  --bg-color: #f0f4f3;
  --text-primary: #1a1a2e;
  --text-secondary: #5b6770;
  --text-tertiary: #9aa6b0;
  --border-color: #e8edec;
}

/* 深色模式变量覆盖 */
@media (prefers-color-scheme: dark) {
  page {
    --bg-color: #1a1a1a;
    --text-primary: #e5e5e5;
    --text-secondary: #a3a3a3;
    --text-tertiary: #737373;
    --border-color: #333333;
  }
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 40rpx;
}

.tabs-wrapper {
  background: var(--card-bg);
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}

.stop-study-btn {
  margin-top: 24rpx;
  padding: 24rpx;
  text-align: center;
  background: var(--bg-color);
  color: var(--text-secondary);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.stop-study-btn:active {
  background: var(--border-color);
}

.tabs {
  display: flex;
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 12rpx;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab-item.active {
  background: var(--header-gradient);
  color: var(--header-text);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

.tab-content {
  padding: 0 30rpx;
}

.study-dashboard {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.group-info-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--shadow);
}

.group-icon {
  font-size: 60rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-light) 0%, #a7f3d0 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.2);
}

/* 深色模式：group-icon */
@media (prefers-color-scheme: dark) {
  .group-icon {
    background: linear-gradient(135deg, #064e3b 0%, #065f46 100%);
  }
}

.group-details {
  flex: 1;
}

.group-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.group-stats {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.today-stats-card {
  background: linear-gradient(135deg, #ffffff 0%, #fafff9 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow);
  border: 1rpx solid rgba(52, 211, 153, 0.08);
}

/* 深色模式：today-stats-card */
@media (prefers-color-scheme: dark) {
  .today-stats-card {
    background: linear-gradient(135deg, #262626 0%, #2a2a2a 100%);
    border-color: rgba(52, 211, 153, 0.15);
  }
}

.today-stats-card .stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-value.today {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-value.review {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-value.time {
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-size: 28rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, var(--border-color), transparent);
}

/* ========== 学习按钮组 ========== */
.study-btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}

.study-btn {
  flex: 1;
  border-radius: 40rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.study-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
  pointer-events: none;
}

.study-btn:active {
  transform: scale(0.98);
}

.study-btn-learn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  box-shadow: 0 8rpx 30rpx rgba(52, 211, 153, 0.3);
}

.study-btn-quiz {
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  box-shadow: 0 8rpx 30rpx rgba(99, 102, 241, 0.3);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--header-text);
}

.study-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}

.quick-action-btn {
  flex: 1;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
  box-shadow: var(--shadow);
}

.quick-action-btn:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-hover);
}

.quick-action-btn.share-btn {
  flex: 1;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
  box-shadow: var(--shadow);
  border: none;
  margin: 0;
  font-size: inherit;
  line-height: initial;
}

.quick-action-btn.share-btn::after {
  border: none;
}

.quick-action-btn.share-btn:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-hover);
}

.clipboard-btn {
  border: 2rpx solid rgba(99, 102, 241, 0.25);
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.06) 0%, rgba(139, 92, 246, 0.06) 100%);
}

.clipboard-btn .action-icon {
  color: #6366f1;
}

.clipboard-btn .action-text {
  color: #6366f1;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.mastery-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.mastery-content {
  display: flex;
  gap: 30rpx;
}

.donut-chart {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.donut-chart::after {
  content: '';
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  background: var(--card-bg);
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.donut-center {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.donut-number {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.donut-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.mastery-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-dot.not-started {
  background: #d1d5db;
}

.legend-dot.basic {
  background: #fbbf24;
}

.legend-dot.good {
  background: #34d399;
}

.legend-dot.difficult {
  background: #f87171;
}

.legend-label {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.legend-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.share-link-btn {
  background: var(--card-bg);
  border: 2rpx solid rgba(99, 102, 241, 0.3);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: var(--shadow);
}

.share-link-btn:active {
  background: rgba(99, 102, 241, 0.08);
}

.share-link-icon {
  font-size: 32rpx;
}

.share-link-text {
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 500;
}

.delete-group-btn {
  background: var(--card-bg);
  border: 2rpx solid rgba(248, 113, 113, 0.3);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: var(--shadow);
}

.delete-group-btn:active {
  background: rgba(248, 113, 113, 0.08);
}

.delete-icon {
  font-size: 32rpx;
}

.delete-text {
  font-size: 26rpx;
  color: #f87171;
  font-weight: 500;
}

.study-mode {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.study-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.study-progress {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-bar {
  height: 8rpx;
  background: var(--bg-color);
  border-radius: 4rpx;
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

/* 深色模式：progress-bar */
@media (prefers-color-scheme: dark) {
  .progress-bar {
    box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
  }
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
  position: relative;
}

.progress-fill::after {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 20rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3));
  border-radius: 4rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.study-exit {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 50%;
  margin-left: 20rpx;
}

/* 实时计时器 */
.study-timer {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-dark);
  background: rgba(52, 211, 153, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
  letter-spacing: 1rpx;
}

/* 深色模式：study-timer */
@media (prefers-color-scheme: dark) {
  .study-timer {
    background: rgba(52, 211, 153, 0.15);
    color: #6ee7b7;
  }
}

/* 深色模式：study-exit */
@media (prefers-color-scheme: dark) {
  .study-exit {
    background: rgba(255, 255, 255, 0.08);
  }
}

.exit-icon {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.card-wrapper {
  perspective: 1000px;
  width: 100%;
  margin-bottom: 30rpx;
}

.study-card {
  position: relative;
  width: 100%;
  min-height: 500rpx;
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.study-card.flipped {
  transform: rotateY(-180deg);
}

.study-card.flip-start {
  transform: rotateY(-15deg);
}

.study-card.flip-end {
  transform: rotateY(-165deg);
}

.study-card.anim-next-out {
  animation: nextOut 0.3s ease forwards;
}

.study-card.anim-next-in {
  animation: nextIn 0.3s ease forwards;
}

.study-card.anim-prev-out {
  animation: prevOut 0.3s ease forwards;
}

.study-card.anim-prev-in {
  animation: prevIn 0.3s ease forwards;
}

@keyframes nextOut {
  from {
    transform: rotateY(0deg);
    opacity: 1;
  }
  to {
    transform: rotateY(-90deg);
    opacity: 0;
  }
}

@keyframes nextIn {
  from {
    transform: rotateY(90deg);
    opacity: 0;
  }
  to {
    transform: rotateY(0deg);
    opacity: 1;
  }
}

@keyframes prevOut {
  from {
    transform: rotateY(0deg);
    opacity: 1;
  }
  to {
    transform: rotateY(90deg);
    opacity: 0;
  }
}

@keyframes prevIn {
  from {
    transform: rotateY(-90deg);
    opacity: 0;
  }
  to {
    transform: rotateY(0deg);
    opacity: 1;
  }
}

.card-face {
  position: absolute;
  width: 100%;
  min-height: 500rpx;
  backface-visibility: hidden;
  background: linear-gradient(145deg, #ffffff 0%, #fafff9 100%);
  border: 1.5px solid rgba(52, 211, 153, 0.12);
  border-radius: 24rpx;
  padding: 44rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(52, 211, 153, 0.08), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-face.back {
  transform: rotateY(-180deg);
  background: linear-gradient(145deg, #ffffff 0%, #fafff9 100%);
  border: 1.5px solid rgba(52, 211, 153, 0.12);
}

/* 深色模式：card-face */
@media (prefers-color-scheme: dark) {
  .card-face,
  .card-face.back {
    background: linear-gradient(145deg, #262626 0%, #2d2d2d 100%);
    border-color: rgba(52, 211, 153, 0.2);
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2), 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  }
}

.mastery-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
  width: 100%;
}

.mastery-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 8rpx;
  border-radius: 20rpx;
  border: 1.5px solid transparent;
  transition: all 0.2s ease;
  background: var(--card-bg);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

/* 深色模式：mastery-btn */
@media (prefers-color-scheme: dark) {
  .mastery-btn {
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  }
}

.mastery-btn:active {
  transform: scale(0.95);
}

.mastery-btn-icon {
  font-size: 36rpx;
}

.mastery-btn-label {
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}

.mastery-btn-new {
  background: rgba(156, 163, 175, 0.1);
  border-color: rgba(156, 163, 175, 0.3);
}

.mastery-btn-new .mastery-btn-label {
  color: #9ca3af;
}

.mastery-btn-new.active {
  background: rgba(156, 163, 175, 0.2);
  border-color: #9ca3af;
}

.mastery-btn-new.active .mastery-btn-label {
  color: #6b7280;
  font-weight: 600;
}

.mastery-btn-learning {
  background: rgba(251, 191, 36, 0.1);
  border-color: rgba(251, 191, 36, 0.25);
}

.mastery-btn-learning .mastery-btn-label {
  color: #d97706;
}

.mastery-btn-learning.active {
  background: rgba(251, 191, 36, 0.2);
  border-color: #fbbf24;
}

.mastery-btn-learning.active .mastery-btn-label {
  color: #b45309;
  font-weight: 600;
}

.mastery-btn-mastered {
  background: rgba(52, 211, 153, 0.1);
  border-color: rgba(52, 211, 153, 0.25);
}

.mastery-btn-mastered .mastery-btn-label {
  color: var(--primary-dark);
}

.mastery-btn-mastered.active {
  background: rgba(52, 211, 153, 0.2);
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 16rpx rgba(52, 211, 153, 0.2);
}

.mastery-btn-mastered.active .mastery-btn-label {
  color: #047857;
  font-weight: 600;
}

.mastery-btn-difficult {
  background: rgba(248, 113, 113, 0.1);
  border-color: rgba(248, 113, 113, 0.25);
}

.mastery-btn-difficult .mastery-btn-label {
  color: #f87171;
}

.mastery-btn-difficult.active {
  background: rgba(248, 113, 113, 0.2);
  border-color: var(--danger-color);
}

.mastery-btn-difficult.active .mastery-btn-label {
  color: #dc2626;
  font-weight: 600;
}

.card-label {
  font-size: 24rpx;
  color: var(--primary-dark);
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  font-weight: 600;
  background: rgba(52, 211, 153, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  line-height: 1.8;
}

.card-text {
  display: block;
  font-size: 34rpx;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.6;
  font-weight: 500;
  white-space: pre-wrap;
}

.card-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 40rpx;
}

.card-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.nav-btn {
  width: 160rpx;
  height: 80rpx;
  background: var(--card-bg);
  color: var(--text-primary);
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid var(--border-color);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 深色模式：nav-btn */
@media (prefers-color-scheme: dark) {
  .nav-btn {
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  }
}

.nav-btn::after {
  border: none;
}

.nav-btn[disabled] {
  background: var(--bg-color);
  color: var(--text-tertiary);
  border-color: transparent;
}

.nav-btn.next {
  border-color: rgba(52, 211, 153, 0.3);
  color: var(--primary-dark);
}

.card-index {
  display: flex;
  align-items: baseline;
  font-size: 28rpx;
}

.card-index .current {
  font-size: 48rpx;
  font-weight: 700;
  color: #059669;
}

.card-index .separator {
  margin: 0 8rpx;
  color: var(--text-tertiary);
}

.card-index .total {
  color: var(--text-tertiary);
}

.catalog-section,
.cards-section,
.favorites-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.add-card-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 30rpx rgba(52, 211, 153, 0.2);
}

.add-icon {
  font-size: 36rpx;
  color: var(--header-text);
  font-weight: 300;
}

.add-text {
  font-size: 28rpx;
  color: var(--header-text);
  font-weight: 600;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.catalog-item,
.card-item,
.favorite-item {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: var(--shadow);
}

.catalog-item {
  flex-direction: row;
  align-items: flex-start;
}

.catalog-num {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--header-text);
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.catalog-content {
  flex: 1;
}

.catalog-question {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.catalog-answer {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  white-space: pre-wrap;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-index {
  width: 40rpx;
  height: 40rpx;
  background: var(--primary-light);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-dark);
  font-size: 20rpx;
  font-weight: 600;
}

.item-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.action-btn.edit {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.action-btn.delete {
  background: rgba(248, 113, 113, 0.1);
  color: var(--danger-color);
}

.item-content {
  flex: 1;
}

.item-question,
.item-answer {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.item-answer {
  margin-bottom: 0;
}

.item-question .label {
  color: var(--primary-color);
  font-weight: 600;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.item-answer .label {
  color: var(--primary-dark);
  font-weight: 600;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.item-question .text,
.item-answer .text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  white-space: pre-wrap;
}

.item-answer .text {
  color: var(--text-secondary);
}

.item-footer {
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.favorite-btn {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  background: var(--bg-color);
  color: var(--text-tertiary);
}

.favorite-btn.favorited {
  background: rgba(251, 191, 36, 0.1);
  color: var(--warning-color);
}

.favorite-item {
  flex-direction: row;
  align-items: flex-start;
}

.favorite-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: var(--warning-color);
  flex-shrink: 0;
}

.favorite-content {
  flex: 1;
}

.favorite-question {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.favorite-answer {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.unfavorite-btn {
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  background: rgba(248, 113, 113, 0.1);
  color: var(--danger-color);
  flex-shrink: 0;
}

.loading-more {
  padding: 30rpx;
  text-align: center;
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 30rpx;
}

.modal-content {
  background: var(--card-bg);
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  text-align: center;
}

.modal-body {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  min-height: 0;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.textarea-field {
  width: 100%;
  padding: 20rpx;
  background: var(--bg-color);
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  min-height: 120rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.btn-cancel:active {
  background: var(--border-color);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--header-text);
}

.btn-confirm:active {
  opacity: 0.9;
}
