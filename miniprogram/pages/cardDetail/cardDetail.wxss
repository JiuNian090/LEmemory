.container {
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #3cc51f;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #3cc51f;
  border-radius: 2rpx;
}

.tab-content {
  padding: 30rpx;
}

.card-container {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  min-height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.card {
  font-size: 32rpx;
  text-align: center;
  color: #333;
}

.card-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-btn {
  width: 160rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #3cc51f;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0;
}

.nav-btn[disabled] {
  background: #ccc;
}

.card-index {
  font-size: 28rpx;
  color: #666;
}

.catalog-item,
.card-item,
.favorite-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-front {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.card-back {
  font-size: 26rpx;
  color: #666;
}

.add-btn {
  background: #3cc51f;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
