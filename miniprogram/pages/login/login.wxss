page {
  background-color: var(--bg-color);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 40rpx 0;
}

/* 通用卡片样式 */
.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  background: linear-gradient(135deg, var(--info-color), #3b82f6);
}

.icon-text {
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-body {
  padding: 30rpx;
}

/* 用户信息卡片 */
.user-info-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar-wrapper {
  position: relative;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--bg-color);
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.user-uid {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 菜单列表 */
.menu-list {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* 操作按钮 */
.action-section {
  padding: 0 30rpx 30rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.action-btn.primary {
  background: var(--header-gradient);
  color: var(--header-text);
}

.action-btn.danger {
  background: var(--danger-gradient);
  color: var(--header-text);
}

.form-container {
  flex: 1;
}

.form {
  max-width: 600rpx;
  margin: 0 auto;
  padding: 0 30rpx;
}

.form-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 0 30rpx;
  height: 100rpx;
  position: relative;
  border: 2rpx solid var(--border-color);
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(52, 211, 153, 0.15);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  opacity: 0.8;
  transition: opacity 0.3s ease;
}

.input-wrapper:focus-within .input-icon {
  opacity: 1;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
}

.toggle-password {
  padding: 10rpx;
  font-size: 32rpx;
  margin-left: 10rpx;
  opacity: 0.6;
  transition: opacity 0.3s ease;
}

.toggle-password:active {
  opacity: 1;
}

.form-options {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.remember-password {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.option-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: var(--header-gradient);
  color: var(--header-text);
  border: none;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(52, 211, 153, 0.35);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

.submit-btn[disabled] {
  opacity: 0.5;
  transform: none !important;
  box-shadow: none !important;
}

.form-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 0;
}

.footer-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.footer-link {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(52, 211, 153, 0.08);
  transition: all 0.3s ease;
}

.footer-link:active {
  background: rgba(52, 211, 153, 0.15);
  transform: scale(0.96);
}

.avatar-input-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.avatar-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 10rpx;
}

.preview-avatar {
  width: 100%;
  height: 100%;
}

.avatar-preview-icon {
  font-size: 36rpx;
}
