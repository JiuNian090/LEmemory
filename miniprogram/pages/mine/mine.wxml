<view class="container">
  <view class="section user-section">
    <view class="section-body" bindtap="handleHeaderClick">
      <view class="user-wrapper">
        <view class="avatar-wrapper">
          <image class="avatar" src="{{userInfo ? (userInfo.avatarUrl || '/images/me.png') : '/images/me.png'}}" mode="aspectFill" />
        </view>
        <view class="user-info">
          <view class="nickname">{{userInfo ? (userInfo.nickName || userInfo.username) : '点击登录'}}</view>
        </view>
        <view class="arrow-wrapper">
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content-section">
    <view class="section" wx:if="{{userInfo}}">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">⚙️</text>
        </view>
        <text class="section-title">功能设置</text>
      </view>
      <view class="section-body">
        <view class="menu-list">
          <view class="menu-item" bindtap="goToBackup">
            <view class="item-left">
              <text class="menu-icon">💾</text>
              <text class="menu-text">数据备份</text>
            </view>
            <view class="item-arrow">›</view>
          </view>
          <view class="menu-item">
            <view class="item-left">
              <text class="menu-icon">⚙️</text>
              <text class="menu-text">设置</text>
            </view>
            <view class="item-arrow">›</view>
          </view>
          <view class="menu-item">
            <view class="item-left">
              <text class="menu-icon">ℹ️</text>
              <text class="menu-text">关于</text>
            </view>
            <view class="item-arrow">›</view>
          </view>
          <view class="menu-item">
            <view class="item-left">
              <text class="menu-icon">💬</text>
              <text class="menu-text">反馈</text>
            </view>
            <view class="item-arrow">›</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{userInfo}}">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">🚪</text>
        </view>
        <text class="section-title">账号</text>
      </view>
      <view class="section-body">
        <view class="menu-list">
          <view class="menu-item logout-item" bindtap="handleLogout">
            <view class="item-left">
              <text class="menu-icon">🚪</text>
              <text class="menu-text logout-text">退出登录</text>
            </view>
            <view class="item-arrow">›</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{!userInfo}}">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">❤️</text>
        </view>
        <text class="section-title">其他</text>
      </view>
      <view class="section-body">
        <view class="menu-list">
          <view class="menu-item">
            <view class="item-left">
              <text class="menu-icon">❤️</text>
              <text class="menu-text">支持我们</text>
            </view>
            <view class="item-arrow">›</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
