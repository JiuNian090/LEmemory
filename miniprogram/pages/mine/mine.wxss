.content-section {
  padding: 0;
}

.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: var(--bg-color);
}

.avatar-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 32rpx;
  height: 32rpx;
  background: var(--primary-color);
  border-radius: 50%;
  border: 4rpx solid var(--card-bg);
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.login-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  border: none;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1;
}

.login-btn::after {
  border: none;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 26rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.item-arrow {
  font-size: 40rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}
