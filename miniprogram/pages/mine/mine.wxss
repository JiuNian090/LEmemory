.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.page-header {
  background: linear-gradient(135deg, rgba(60, 197, 31, 0.15) 0%, rgba(45, 170, 21, 0.1) 100%);
  padding: 40rpx 30rpx;
  margin: 30rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(60, 197, 31, 0.2);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3cc51f;
}

.content-section {
  padding: 0;
}

.user-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 0 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 30rpx rgba(60, 197, 31, 0.12);
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f5f7fa;
}

.avatar-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 32rpx;
  height: 32rpx;
  background: #4ade80;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999;
}

.login-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #3cc51f 0%, #2daa15 100%);
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  border: none;
  color: #fff;
  font-size: 26rpx;
  line-height: 1;
}

.login-btn::after {
  border: none;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 26rpx;
}

.menu-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 10rpx;
  border-bottom: 1rpx solid #f5f7fa;
}

.menu-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.item-arrow {
  font-size: 40rpx;
  color: #ddd;
  font-weight: 300;
}
