page {
  background: var(--bg-color);
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.user-section {
  margin: 0 30rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.user-section .section-body {
  padding: 40rpx 30rpx;
  background: var(--header-gradient);
}

.user-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.2);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-hint {
  font-size: 24rpx;
  color: var(--header-text-secondary);
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--header-text);
}

.arrow-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

.content-section {
  padding: 0;
}

.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.data-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.icon-text {
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-body {
  padding: 0 30rpx 30rpx;
}

.menu-list {
  padding-top: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

.weui-btn-area {
  margin: 40rpx 30rpx 30rpx;
}

.weui-btn {
  position: relative;
  display: block;
  width: 100%;
  margin-left: auto;
  margin-right: auto;
  padding: 0;
  box-sizing: border-box;
  font-size: 36rpx;
  text-align: center;
  text-decoration: none;
  color: var(--text-primary);
  line-height: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
  overflow: hidden;
  border: none;
  outline: none;
}

.weui-btn_warn {
  background-color: var(--danger-color);
  color: var(--header-text);
}