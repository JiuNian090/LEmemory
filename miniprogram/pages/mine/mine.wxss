page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.user-section {
  margin: 0 30rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.user-section .section-body {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
}

.user-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.2);
}

.user-info {
  display: flex;
  align-items: center;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
}

.arrow-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

.content-section {
  padding: 0;
}

.section {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.data-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.icon-text {
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-body {
  padding: 0 30rpx 30rpx;
}

.menu-list {
  padding-top: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f8f8f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #1a1a1a;
}

.item-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

.logout-item .menu-text {
  color: #f87171;
}
