<view class="container">
  <view class="section" wx:if="{{userInfo}}">
    <view class="section-header">
      <view class="section-icon profile-icon">
        <text class="icon-text">👤</text>
      </view>
      <text class="section-title">个人信息</text>
    </view>
    <view class="section-body">
      <view class="menu-list">
        <view class="menu-item" bindtap="chooseAvatar">
          <view class="item-left">
            <text class="menu-icon">📷</text>
            <text class="menu-text">头像</text>
          </view>
          <view class="item-right">
            <image class="avatar-small" src="{{avatarUrl || '/images/me.png'}}" mode="aspectFill" />
            <text class="item-arrow">›</text>
          </view>
        </view>
        <view class="menu-item" bindtap="showNickNameEdit">
          <view class="item-left">
            <text class="menu-icon">😊</text>
            <text class="menu-text">昵称</text>
          </view>
          <view class="item-right">
            <text class="item-value">{{nickName}}</text>
            <text class="item-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{userInfo}}">
    <view class="section-header">
      <view class="section-icon security-icon">
        <text class="icon-text">🔒</text>
      </view>
      <text class="section-title">账号安全</text>
    </view>
    <view class="section-body">
      <view class="menu-list">
        <view class="menu-item" bindtap="showPasswordEdit">
          <view class="item-left">
            <text class="menu-icon">🔑</text>
            <text class="menu-text">修改密码</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{!userInfo}}">
    <view class="section-body">
      <view class="empty-tip">请先登录后再进行设置</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showNickNameModal}}" bindtap="hideNickNameModal">
  <view class="modal-content" catchtap="">
    <view class="modal-title">修改昵称</view>
    <view class="modal-body">
      <input
        class="modal-input"
        placeholder="请输入新昵称"
        value="{{newNickName}}"
        bindinput="onNickNameInput"
        maxlength="20"
      />
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="hideNickNameModal">取消</view>
      <view class="modal-btn confirm" bindtap="saveNickName">保存</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showPasswordModal}}" bindtap="hidePasswordModal">
  <view class="modal-content" catchtap="">
    <view class="modal-title">修改密码</view>
    <view class="modal-body">
      <view class="password-field">
        <input
          class="modal-input"
          placeholder="当前密码"
          password="{{!showOldPassword}}"
          value="{{oldPassword}}"
          bindinput="onOldPasswordInput"
          maxlength="50"
        />
        <view class="toggle-pwd" bindtap="toggleOldPassword">
          <text>{{showOldPassword ? '🙈' : '👁️'}}</text>
        </view>
      </view>
      <view class="password-field">
        <input
          class="modal-input"
          placeholder="新密码（至少6个字符）"
          password="{{!showNewPassword}}"
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
          maxlength="50"
        />
        <view class="toggle-pwd" bindtap="toggleNewPassword">
          <text>{{showNewPassword ? '🙈' : '👁️'}}</text>
        </view>
      </view>
      <view class="password-field">
        <input
          class="modal-input"
          placeholder="确认新密码"
          password="{{!showNewPassword}}"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          maxlength="50"
        />
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="hidePasswordModal">取消</view>
      <view class="modal-btn confirm" bindtap="savePassword">保存</view>
    </view>
  </view>
</view>
