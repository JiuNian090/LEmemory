page {
  background: var(--bg-color);
}

.container {
  min-height: 100vh;
  padding: 30rpx 0 40rpx;
}

.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.profile-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.security-icon {
  background: linear-gradient(135deg, #fef3c7 0%, #fef9c3 100%);
}

.icon-text {
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-body {
  padding: 0 30rpx 10rpx;
}

.menu-list {
  padding-top: 10rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-value {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.item-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

.avatar-small {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--border-color);
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--mask-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  padding: 40rpx 30rpx 20rpx;
}

.modal-body {
  padding: 20rpx 30rpx 30rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.password-field {
  position: relative;
  margin-bottom: 20rpx;
}

.password-field:last-child {
  margin-bottom: 0;
}

.password-field .modal-input {
  padding-right: 80rpx;
}

.toggle-pwd {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 10rpx;
  font-size: 32rpx;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid var(--border-color);
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  color: var(--text-tertiary);
  border-right: 2rpx solid var(--border-color);
}

.modal-btn.confirm {
  color: var(--primary-color);
}

.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  pointer-events: none;
  transition: background 0.3s ease;
}

.sheet-mask--show {
  background: var(--mask-bg);
  pointer-events: auto;
}

.sheet-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet-panel--show {
  transform: translateY(0);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  background: var(--border-color);
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  padding: 24rpx 30rpx 20rpx;
}

.sheet-body {
  padding: 0 40rpx 30rpx;
}

.sheet-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.sheet-pwd-field {
  position: relative;
  margin-bottom: 20rpx;
}

.sheet-pwd-field:last-child {
  margin-bottom: 0;
}

.sheet-pwd-field .sheet-input {
  padding-right: 80rpx;
}

.sheet-pwd-toggle {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 10rpx;
  font-size: 32rpx;
}

.sheet-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 30rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.sheet-btn--cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.sheet-btn--confirm {
  background: var(--header-gradient);
  color: var(--header-text);
}

.sheet-confirm-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  padding: 10rpx 0;
}

.sheet-btn--danger {
  background: var(--danger-gradient);
  color: var(--header-text);
}

.account-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.account-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: var(--bg-color);
  transition: background 0.2s;
}

.account-item:active {
  background: var(--border-color);
}

.account-item--active {
  background: var(--primary-light);
  border: 2rpx solid var(--primary-color);
}

.account-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--border-color);
}

.account-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.account-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-username {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  margin-left: 16rpx;
}