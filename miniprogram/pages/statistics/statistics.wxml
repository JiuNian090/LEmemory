<view class="container">
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">📊 学习统计</text>
      <text class="header-subtitle">了解你的学习进度</text>
    </view>
  </view>

  <view class="content-section">
    <!-- 总学习时长 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">⏱️</text>
        </view>
        <text class="section-title">总学习时长</text>
      </view>
      <view class="section-body">
        <view class="total-value">{{formattedDuration}}</view>
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-icon">📚</view>
        <view class="stat-value">{{groupCount}}</view>
        <view class="stat-label">卡牌组数</view>
      </view>
      <view class="stat-item">
        <view class="stat-icon">🎴</view>
        <view class="stat-value">{{cardCount}}</view>
        <view class="stat-label">卡牌总数</view>
      </view>
    </view>

    <!-- 近期学习趋势 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📈</text>
        </view>
        <text class="section-title">近7天学习趋势</text>
      </view>
      <view class="section-body">
        <view class="trend-chart" wx:if="{{weekTrend.length > 0}}">
          <view class="trend-item" wx:for="{{weekTrend}}" wx:key="date">
            <view class="trend-bar-wrapper">
              <view class="trend-bar" style="height: {{item.duration > 0 ? Math.max(20, (item.duration / maxDuration) * 200) : 0}}rpx"></view>
            </view>
            <view class="trend-label">{{item.date}}</view>
            <view class="trend-value">{{item.duration > 0 ? formatDuration(item.duration) : '-'}}</view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
          <view class="empty-text">暂无学习记录</view>
        </view>
      </view>
    </view>

    <!-- 各卡牌组学习时长 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📊</text>
        </view>
        <text class="section-title">各卡牌组学习时长</text>
      </view>
      <view class="section-body">
        <view class="group-list" wx:if="{{groupDurations.length > 0}}">
          <view class="group-item" wx:for="{{groupDurations}}" wx:key="groupId">
            <view class="group-info">
              <view class="group-title">{{item.title}}</view>
              <view class="group-duration">{{formatDuration(item.duration)}}</view>
            </view>
            <view class="group-bar-wrapper">
              <view class="group-bar" style="width: {{(item.duration / maxGroupDuration) * 100}}%"></view>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
          <view class="empty-text">暂无学习记录</view>
        </view>
      </view>
    </view>
  </view>
</view>
