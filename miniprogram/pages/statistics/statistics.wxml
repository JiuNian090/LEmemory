<view class="container">
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">📊 学习统计</text>
      <text class="header-subtitle">了解你的学习进度</text>
    </view>
  </view>

  <view class="content-section">
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">⏱️</text>
        </view>
        <text class="section-title">总学习时长</text>
      </view>
      <view class="section-body">
        <view class="total-value">{{formattedDuration}}</view>
      </view>
    </view>

    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-icon">📊</view>
        <view class="stat-value">{{totalDuration}}</view>
        <view class="stat-label">学习时长(秒)</view>
      </view>
      <view class="stat-item">
        <view class="stat-icon">📚</view>
        <view class="stat-value">{{groupCount}}</view>
        <view class="stat-label">卡牌组数</view>
      </view>
      <view class="stat-item">
        <view class="stat-icon">🎴</view>
        <view class="stat-value">{{cardCount}}</view>
        <view class="stat-label">卡牌总数</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📈</text>
        </view>
        <text class="section-title">近期学习趋势</text>
      </view>
      <view class="section-body">
        <view class="chart-placeholder">
          <image class="placeholder-icon" src="/images/status.png" mode="aspectFit"></image>
          <text class="placeholder-text">图表功能开发中</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📊</text>
        </view>
        <text class="section-title">各卡牌组学习时长</text>
      </view>
      <view class="section-body">
        <view class="chart-placeholder">
          <image class="placeholder-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
          <text class="placeholder-text">图表功能开发中</text>
        </view>
      </view>
    </view>
  </view>
</view>
