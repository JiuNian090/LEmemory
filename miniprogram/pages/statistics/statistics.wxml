<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">📊 学习统计</text>
      <text class="header-subtitle">全方位了解你的学习状态</text>
    </view>
  </view>

  <view class="content-section">
    <!-- 时间筛选器 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📅</text>
        </view>
        <text class="section-title">时间范围</text>
      </view>
      <view class="section-body">
        <view class="quick-buttons">
          <view class="quick-btn {{activeQuickBtn === 'week' ? 'active' : ''}}" bindtap="onQuickTap" data-type="week">本周</view>
          <view class="quick-btn {{activeQuickBtn === 'month' ? 'active' : ''}}" bindtap="onQuickTap" data-type="month">本月</view>
          <view class="quick-btn {{activeQuickBtn === 'year' ? 'active' : ''}}" bindtap="onQuickTap" data-type="year">本年</view>
          <view class="quick-btn {{activeQuickBtn === 'all' ? 'active' : ''}}" bindtap="onQuickTap" data-type="all">全部</view>
        </view>
        <view class="date-picker-row">
          <picker mode="date" value="{{startDate}}" bindchange="onDateChange" data-field="start" class="date-picker">
            <view class="date-display">
              <text class="date-label">开始</text>
              <text class="date-value">{{startDate}}</text>
            </view>
          </picker>
          <text class="date-separator">至</text>
          <picker mode="date" value="{{endDate}}" bindchange="onDateChange" data-field="end" class="date-picker">
            <view class="date-display">
              <text class="date-label">结束</text>
              <text class="date-value">{{endDate}}</text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 概览卡片 -->
    <view class="section overview-section">
      <view class="section-body">
        <view class="overview-main">
          <text class="overview-value">{{formattedDuration}}</text>
          <text class="overview-label">总学习时长</text>
          <view class="overview-change {{changeDirection}}">
            <text>{{changeText}}</text>
            <text class="change-sub">vs 上{{periodLabel}}</text>
          </view>
        </view>
        <view class="overview-grid">
          <view class="overview-cell">
            <text class="cell-value">{{studyDays}}</text>
            <text class="cell-label">达标天数</text>
          </view>
          <view class="overview-cell">
            <text class="cell-value">{{currentStreak}} 🔥</text>
            <text class="cell-label">连续打卡</text>
          </view>
          <view class="overview-cell">
            <text class="cell-value">{{achievementRate}}%</text>
            <text class="cell-label">目标达成</text>
          </view>
          <view class="overview-cell">
            <text class="cell-value">{{groupCount}}</text>
            <text class="cell-label">卡牌组数</text>
          </view>
        </view>
        <view class="goal-setting">
          <picker mode="multiSelector" range="{{goalPickerRange}}" value="{{goalPickerValue}}" bindchange="onGoalPickerChange" class="goal-picker">
            <view class="goal-picker-inner">
              <text>每日目标：{{dailyGoalMinutes}} 分钟</text>
              <text class="goal-edit">点击修改</text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 趋势折线图 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📈</text>
        </view>
        <text class="section-title">学习时长趋势</text>
      </view>
      <view class="section-body">
        <canvas type="2d" id="trendChart" class="chart-canvas" bindtouchstart="onChartTap"></canvas>
      </view>
    </view>

    <!-- 学习热力图 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">🔥</text>
        </view>
        <text class="section-title">学习热力图</text>
        <text class="section-extra">{{heatmapYear}} 年</text>
      </view>
      <view class="section-body">
        <canvas type="2d" id="heatmapChart" class="chart-canvas heatmap-canvas" bindtouchstart="onHeatmapTap"></canvas>
        <view class="heatmap-legend">
          <text class="legend-text">少</text>
          <view class="legend-cell" style="background: var(--primary-color); opacity: 0.1;"></view>
          <view class="legend-cell" style="background: var(--primary-color); opacity: 0.3;"></view>
          <view class="legend-cell" style="background: var(--primary-color); opacity: 0.5;"></view>
          <view class="legend-cell" style="background: var(--primary-color); opacity: 0.7;"></view>
          <view class="legend-cell" style="background: var(--primary-color); opacity: 1;"></view>
          <text class="legend-text">多</text>
        </view>
      </view>
    </view>

    <!-- 月度柱状图 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📊</text>
        </view>
        <text class="section-title">月度统计</text>
      </view>
      <view class="section-body">
        <canvas type="2d" id="monthlyChart" class="chart-canvas" bindtouchstart="onChartTap"></canvas>
      </view>
    </view>

    <!-- 卡牌组占比饼图 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">🥧</text>
        </view>
        <text class="section-title">卡牌组学习分布</text>
      </view>
      <view class="section-body">
        <canvas type="2d" id="pieChart" class="chart-canvas pie-canvas" bindtouchstart="onChartTap"></canvas>
      </view>
    </view>

    <!-- 各卡牌组学习时长明细 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon data-icon">
          <text class="icon-text">📋</text>
        </view>
        <text class="section-title">卡牌组时长明细</text>
      </view>
      <view class="section-body">
        <view class="group-list" wx:if="{{groupPieData.length > 0}}">
          <view class="group-item" wx:for="{{groupPieData}}" wx:key="groupId" wx:for-item="g">
            <view class="group-info">
              <view class="group-color" style="background: {{g.color}}"></view>
              <view class="group-title">{{g.title}}</view>
              <view class="group-duration">{{g.formattedValue}}</view>
            </view>
            <view class="group-bar-wrapper">
              <view class="group-bar" style="width: {{g.percentage}}%"></view>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <image class="empty-icon" src="/images/book.png" mode="aspectFit"></image>
          <view class="empty-text">暂无学习记录</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 目标设置弹窗 -->
</view>
