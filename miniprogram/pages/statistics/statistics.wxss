.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.page-header {
  background: linear-gradient(135deg, rgba(60, 197, 31, 0.15) 0%, rgba(45, 170, 21, 0.1) 100%);
  padding: 40rpx 30rpx;
  margin: 30rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(60, 197, 31, 0.2);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3cc51f;
}

.content-section {
  padding: 0;
}

.total-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 0 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(60, 197, 31, 0.12);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.header-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.5;
  margin-right: 12rpx;
}

.header-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.card-body {
  display: flex;
  justify-content: center;
}

.total-value {
  font-size: 64rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #3cc51f 0%, #2daa15 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stats-grid {
  display: flex;
  gap: 20rpx;
  margin: 0 30rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.chart-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.chart-container {
  min-height: 320rpx;
}

.chart-placeholder {
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.placeholder-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.2;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #999;
}
