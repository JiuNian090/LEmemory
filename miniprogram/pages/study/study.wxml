<view class="container">
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">📚 我的卡牌组</text>
      <text class="header-subtitle">管理和学习你的卡牌</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-icon data-icon">
        <text class="icon-text">🎴</text>
      </view>
      <text class="section-title">卡牌组</text>
      <view class="section-right">
        <button class="add-btn" bindtap="createCardGroup" style="width: 154rpx; display: flex; box-sizing: border-box; left: 0rpx; top: 0rpx; height: 58rpx">
          <text class="add-icon">+</text>
          <text class="add-text">新建</text>
        </button>
      </view>
    </view>
  </view>

  <view class="content-section">
    <block wx:if="{{cardGroups.length > 0}}">
      <view class="card-grid" bindtap="closeAllSwipes">
        <block wx:for="{{cardGroups}}" wx:key="groupId">
          <view class="swipe-container">
            <view class="swipe-bg" bindtap="onDeleteGroup" data-groupid="{{item.groupId}}" data-title="{{item.title}}">
              <text>删除</text>
            </view>
            <view class="card-item {{item._swipeOpen ? 'swiped' : ''}}" 
              bindtap="goToDetail" 
              bindlongpress="onLongPressDelete"
              bindtouchstart="onTouchStart"
              bindtouchmove="onTouchMove"
              bindtouchend="onTouchEnd"
              data-index="{{index}}"
              data-groupid="{{item.groupId}}" 
              data-title="{{item.title}}">
              <view class="card-icon">
                <text class="icon-text">🎴</text>
              </view>
              <view class="card-content">
                <view class="card-title">{{item.title}}</view>
                <view class="card-desc" wx:if="{{item.description}}">{{item.description}}</view>
                <view class="card-meta">
                  <text class="meta-item">{{item.updateTime}}</text>
                </view>
              </view>
              <view class="card-arrow">›</view>
            </view>
          </view>
        </block>
      </view>
    </block>
    <block wx:else>
      <view class="empty-state">
        <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
        <view class="empty-text">暂无卡牌组</view>
        <view class="empty-desc">点击上方按钮开始创建</view>
      </view>
    </block>
  </view>

  <!-- 创建卡牌组弹窗 -->
  <view class="modal-overlay" wx:if="{{showCreateDialog}}" bindtap="closeDialog">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">新建卡牌组</text>
      </view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">标题 *</text>
          <input class="input-field" placeholder="请输入卡牌组标题" value="{{newTitle}}" bindinput="onTitleInput" maxlength="30"/>
        </view>
        <view class="input-group">
          <text class="input-label">描述</text>
          <textarea class="textarea-field" placeholder="描述一下这个卡牌组（可选）" value="{{newDesc}}" bindinput="onDescInput" maxlength="100" auto-height/>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-cancel" bindtap="closeDialog">取消</button>
        <button class="btn btn-confirm" bindtap="confirmCreate">创建</button>
      </view>
    </view>
  </view>
</view>
