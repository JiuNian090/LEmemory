<view class="container">
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">📚 我的卡牌组</text>
      <text class="header-subtitle">管理和学习你的卡牌</text>
    </view>
  </view>

  <view class="content-section">
    <block wx:if="{{cardGroups.length > 0}}">
      <view class="card-grid">
        <block wx:for="{{cardGroups}}" wx:key="groupId">
          <view class="card-item" bindtap="goToDetail" data-groupid="{{item.groupId}}" data-title="{{item.title}}">
            <view class="card-icon">
              <text class="icon-text">🎴</text>
            </view>
            <view class="card-content">
              <view class="card-title">{{item.title}}</view>
              <view class="card-desc" wx:if="{{item.description}}">{{item.description}}</view>
              <view class="card-meta">
                <text class="meta-item">{{item.createTime}}</text>
              </view>
            </view>
            <view class="card-arrow">›</view>
          </view>
        </block>
      </view>
    </block>
    <block wx:else>
      <view class="empty-state">
        <image class="empty-icon" src="/images/graduation-hat-2.png" mode="aspectFit"></image>
        <view class="empty-text">暂无卡牌组</view>
        <view class="empty-desc">点击下方按钮开始创建</view>
      </view>
    </block>
  </view>

  <view class="fixed-action-btn">
    <button class="create-btn" bindtap="createCardGroup">
      <text class="create-icon">+</text>
      <text class="create-text">新建卡牌组</text>
    </button>
  </view>
</view>
