.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, rgba(60, 197, 31, 0.15) 0%, rgba(45, 170, 21, 0.1) 100%);
  margin: 30rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(60, 197, 31, 0.2);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3cc51f;
}

.create-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #3cc51f 0%, #2daa15 100%);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  border: none;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
  box-shadow: 0 4rpx 16rpx rgba(60, 197, 31, 0.3);
}

.create-btn::after {
  border: none;
}

.create-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
  font-weight: 300;
}

.create-text {
  font-size: 26rpx;
}

.content-section {
  padding: 0;
}

.card-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 30rpx;
}

.card-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.card-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #3cc51f 0%, #2daa15 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-img {
  width: 50rpx;
  height: 50rpx;
  filter: brightness(0) invert(1);
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.card-arrow {
  font-size: 48rpx;
  color: #ddd;
  font-weight: 300;
  margin-left: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}
