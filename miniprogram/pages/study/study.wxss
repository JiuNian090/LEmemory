.content-section {
  padding: 0;
}

.card-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 30rpx;
}

.card-item {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
}

.card-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-hover);
}

.card-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 48rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.card-arrow {
  font-size: 48rpx;
  color: var(--text-tertiary);
  font-weight: 300;
  margin-left: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.fixed-action-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 100;
}

.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 44rpx;
  padding: 24rpx 32rpx;
  border: none;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
  box-shadow: 0 4rpx 20rpx rgba(52, 211, 153, 0.4);
  width: 100%;
}

.create-btn::after {
  border: none;
}

.create-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
  font-weight: 300;
}

.create-text {
  font-size: 28rpx;
  font-weight: 500;
}
