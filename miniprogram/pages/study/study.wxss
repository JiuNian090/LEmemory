.container {
  padding: 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #3cc51f;
  color: #fff;
  font-size: 40rpx;
  line-height: 80rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-group-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-group-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.item-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.item-time {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
