.content-section {
  padding: 0;
  padding-bottom: 40rpx;
}

/* ========== 区块卡片 ========== */
.section {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  transform: translateY(0);
  opacity: 1;
  transition: all 0.3s ease;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  position: relative;
  justify-content: space-between;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.data-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
}

.section-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-right {
  display: flex;
  align-items: center;
}

.add-btn {
  padding: 10rpx 8rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(52, 211, 153, 0.3);
}

.add-btn::after {
  border: none;
}

.add-icon {
  font-size: 32rpx;
  color: var(--header-text);
  font-weight: 300;
  line-height: 1;
  margin-right: 8rpx;
}

.add-text {
  font-size: 28rpx;
  color: var(--header-text);
  font-weight: 500;
  line-height: 1;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 30rpx;
}

/* 左滑删除 - 触摸事件方案 */
.swipe-item {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  height: 150rpx;
}

.swipe-content {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  background: var(--card-bg);
  border-radius: 24rpx;
  transition: transform 0.25s ease;
  box-shadow: var(--shadow);
}

.swipe-item.swiped .swipe-content {
  transform: translateX(-160rpx);
}

.card-item {
  padding: 30rpx;
  display: flex;
  align-items: center;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.card-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-hover);
}

/* 删除按钮（隐藏于右侧） */
.swipe-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  width: 160rpx;
  height: 100%;
  z-index: 1;
  background: linear-gradient(135deg, #f87171 0%, #dc2626 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 0 24rpx 24rpx 0;
}

.delete-icon {
  font-size: 40rpx;
}

.delete-text {
  font-size: 26rpx;
  color: var(--header-text);
  font-weight: 500;
}

.card-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 48rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.card-arrow {
  font-size: 48rpx;
  color: var(--text-tertiary);
  font-weight: 300;
  margin-left: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}



.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--mask-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 30rpx;
}

.modal-content {
  background: var(--card-bg);
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-body {
  padding: 30rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 72rpx;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: var(--text-primary);
  box-sizing: border-box;
}

.textarea-field {
  width: 100%;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  min-height: 150rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid var(--border-color);
  gap: 20rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--header-text);
}
